{
  "skill_file": "skills/drupal-rules/SKILL.md",
  "assertions": [
    {
      "id": "S01",
      "description": "Skill file exists",
      "check": "file_exists",
      "path": "skills/drupal-rules/SKILL.md"
    },
    {
      "id": "S02",
      "description": "Frontmatter has required fields (name, description)",
      "check": "frontmatter_fields",
      "fields": ["name", "description"]
    },
    {
      "id": "S03",
      "description": "Warns against \\Drupal:: static calls",
      "check": "contains",
      "text": "\\Drupal::"
    },
    {
      "id": "S04",
      "description": "Mentions accessCheck(TRUE) requirement",
      "check": "contains",
      "text": "accessCheck(TRUE)"
    },
    {
      "id": "S05",
      "description": "Mentions #cache metadata requirement",
      "check": "contains",
      "text": "#cache"
    },
    {
      "id": "S06",
      "description": "Mentions declare(strict_types=1)",
      "check": "contains",
      "text": "declare(strict_types=1)"
    },
    {
      "id": "S07",
      "description": "Mentions TranslatableMarkup or ->t() for strings",
      "check": "contains",
      "text": "->t("
    },
    {
      "id": "S08",
      "description": "Skill file is under 200 lines",
      "check": "max_lines",
      "limit": 200
    }
  ]
}
