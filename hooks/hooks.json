{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{
          "type": "command",
          "command": "echo \"$CLAUDE_PLUGIN_ROOT\" > /tmp/drupal-workflow-plugin-root; echo 'DRUPAL WORKFLOW PLUGIN ACTIVE | Start: /drupal-bootstrap | Prime: /drupal-prime | Status: /drupal-status | Semantic: /drupal-semantic | Test: /drupal-test | Verify: /drupal-verify'",
          "timeout": 3000,
          "once": true,
          "statusMessage": "Drupal workflow init"
        }]
      },
      {
        "matcher": "startup",
        "hooks": [{
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/project-state-check.sh\" 2>/dev/null; exit 0",
          "timeout": 15000,
          "once": true,
          "statusMessage": "Checking project docs"
        }]
      },
      {
        "hooks": [{
          "type": "command",
          "command": "echo 'Hook registry: OK (all SessionStart hooks passed)'",
          "timeout": 3000,
          "once": true
        }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/block-sensitive-files.sh",
          "timeout": 5000,
          "statusMessage": "Checking sensitive files"
        }]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/plan-mode-inject.sh",
          "timeout": 3000,
          "statusMessage": "Injecting plan instructions"
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/php-lint-on-save.sh",
          "timeout": 10000,
          "once": false,
          "statusMessage": "PHP lint check"
        }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/staleness-check.sh",
          "timeout": 5000,
          "once": false,
          "statusMessage": "Staleness check"
        }]
      }
    ],
    "Stop": [
      {
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/stop-verification-gate.sh",
          "timeout": 5000,
          "statusMessage": "Verification gate"
        }]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/subagent-context-inject.sh",
          "timeout": 5000,
          "statusMessage": "Injecting Drupal context"
        }]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": ".*",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/teammate-quality-gate.sh",
          "timeout": 10000,
          "statusMessage": "Verification check"
        }]
      }
    ]
  }
}
